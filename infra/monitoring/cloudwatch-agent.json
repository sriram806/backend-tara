{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/lib/docker/containers/*/*.log",
            "log_group_name": "/thinkai/services",
            "log_stream_name": "{instance_id}/{hostname}",
            "retention_in_days": 30
          }
        ]
      }
    }
  }
}
