    "@socket.io/redis-adapter": "^8.3.0",
    "@thinkai/config": "workspace:*",
    "@thinkai/types": "workspace:*",
    "fastify": "^5.2.1",
    "ioredis": "^5.10.1",
    "socket.io": "^4.8.3"
  }
