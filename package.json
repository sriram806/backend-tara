{
  "name": "thinkai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @thinkai/gateway dev",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test:node": "jest -c tests/node/jest.config.cjs --runInBand",
    "test:python": "python -m pytest services/ai-service/tests -q",
    "test:load:smoke": "k6 run tests/load/auth-load.k6.js",
    "test:system:0111": "pnpm test:node ; pnpm test:python"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
